# Canton Validator & Wallet Configuration Example

# Admin / API tokens
ADMIN_TOKEN=<your_admin_token_here>

# Testnet / Validator secrets
TESTNET_SECRET=<your_testnet_secret_here>
VALIDATOR_PARTY=<your_validator_party_here>
DSO_PARTY=<your_dso_party_here>
PACKAGE_ID=<your_package_id_here>

# gRPC host
GRPC_HOST=localhost:5001

# JWT configuration
JWT_SECRET=<your_jwt_secret_here>  
JWT_AUDIENCE=https://validator.example.com

# Validator URL
VALIDATOR_URL=http://localhost:8080

# Validator audience (must match the JWT 'aud' claim your validator expects)
VALIDATOR_AUTH_AUDIENCE=<your_validator_audience_here>

# Authentication mode
AUTH_MODE=auth0

# Auth0 configuration for validator authentication
VALIDATOR_AUTH_CLIENT_ID=<your_validator_auth_client_id_here>
VALIDATOR_AUTH_CLIENT_SECRET=<your_validator_auth_client_secret_here>
AUTH0_DOMAIN=<your_auth0_domain_here>

# Wallet web UI
WALLET_UI_CLIENT_ID=<your_wallet_ui_client_id_here>

# ANS web UI
ANS_UI_CLIENT_ID=<your_ans_ui_client_id_here>

# Auth0 credentials for wallet authentication (if needed)
AUTH0_WALLET_USERNAME=<your_wallet_username_here>
AUTH0_WALLET_PASSWORD=<your_wallet_password_here>

# Ledger API admin user
LEDGER_API_ADMIN_USER=<your_ledger_api_admin_user_here>

# Test wallet password
TEST_WALLET_PASSWORD=<your_test_wallet_password_here>